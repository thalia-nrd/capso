generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}    

/// ----------------------
/// USERS
/// ----------------------
model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cabinets  Cabinet[]
}

/// ----------------------
/// CABINETS
/// ----------------------
model Cabinet {
  id          Int       @id @default(autoincrement())
  title       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id])
  ownerId     Int       @unique

  layout      CabinetLayout[]
  chest       Chest?
  journal     Journal?
  photoFrame  PhotoFrame[]
  media       Media[]
  checklist   Checklist[]
  notes       Note[]
}

/// ----------------------
/// CABINET LAYOUT
/// ----------------------
model CabinetLayout {
  id        Int      @id @default(autoincrement())
  name      String?  // optional: name/version of layout
  layout    Json     // array of objects {itemType, itemId, position}
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// SYSTEM ITEMS (global decor / mirror / mp3)
/// ----------------------
model SystemItem {
  id        Int      @id @default(autoincrement())
  type      String   // "mirror", "mp3", "lamp", "image", etc.
  metadata  Json?    // dynamic data like cover image, API info
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// CHEST
/// ----------------------
model Chest {
  id        Int      @id @default(autoincrement())
  passcode  String
  position  Json?
  items     Json?    // could hold IDs of media / photoFrame etc inside chest
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// JOURNAL
/// ----------------------
model Journal {
  id        Int      @id @default(autoincrement())
  passcode  String
  position  Json?
  entries   Json
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// PHOTO FRAME
/// ----------------------
model PhotoFrame {
  id        Int      @id @default(autoincrement())
  position  Json?
  url       String
  caption   String?
  metadata  Json?    // dynamic info like effects
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// MEDIA
/// ----------------------
model Media {
  id        Int      @id @default(autoincrement())
  position  Json?
  type      String
  url       String
  metadata  Json?    // dynamic info, e.g., song/playlist data
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// CHECKLIST
/// ----------------------
model Checklist {
  id        Int      @id @default(autoincrement())
  position  Json?
  title     String
  items     Json
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ----------------------
/// NOTE
/// ----------------------
model Note {
  id        Int      @id @default(autoincrement())
  position  Json?
  content   String
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id])
  cabinetId Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}