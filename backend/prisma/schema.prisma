generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
}    

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  frame     Frame[]
  spotifyAccount SpotifyAccount?
}

model Frame {
  id          Int      @id @default(autoincrement())
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
  ownerId     Int      @unique

  layout      FrameLayout?
  chest       Chest?
  journal     Journal?
  polaroid    Polaroid[]
  media       Media[]
  checklist   Checklist[]
  notes       Note[]
  decorItems  DecorItem[]
}

model FrameLayout {
  id        Int      @id @default(autoincrement())
  layout    Json
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chest {
  id        Int      @id @default(autoincrement())
  passcode  String
  position  Json?
  items     Json?
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Journal {
  id        Int      @id @default(autoincrement())
  passcode  String
  position  Json?
  entries   Json
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Polaroid {
  id        Int      @id @default(autoincrement())
  position  Json?
  url       String
  caption   String?
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        Int      @id @default(autoincrement())
  position  Json?
  type      String
  url       String
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Checklist {
  id        Int      @id @default(autoincrement())
  position  Json?
  title     String
  items     Json
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        Int      @id @default(autoincrement())
  position  Json?
  content   String
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DecorItem {
  id        Int      @id @default(autoincrement())
  position  Json?
  type      String
  frame     Frame  @relation(fields: [frameId], references: [id])
  frameId   Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mp3Item {
  id        Int      @id @default(autoincrement())
  frameId   Int
  playlist  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpotifyAccount {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int      @unique
  accessToken  String
  refreshToken String
  scope        String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}